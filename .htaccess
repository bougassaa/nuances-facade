# Desactive MultiViews : sinon OVH transforme /contact en /contact.php AVANT
# nos regles, ce qui casse les redirections. On gere le mapping .php nous-memes.
Options -MultiViews

RewriteEngine On

# ============================================================
#  1. URL CANONIQUE : une seule redirection 301 vers
#     https://www.nuances-facade.fr  (force HTTPS + www en 1 saut)
# ============================================================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\.nuances-facade\.fr$ [NC]
RewriteRule ^ https://www.nuances-facade.fr%{REQUEST_URI} [R=301,L]

# ============================================================
#  2. /index.php et /index  ->  /   (301)
# ============================================================
RewriteCond %{THE_REQUEST} \s/+index(\.php)?[\s?] [NC]
RewriteRule ^ https://www.nuances-facade.fr/ [R=301,L]

# ============================================================
#  3. Supprimer l'extension .php visible  ->  URL propre (301)
#     - uniquement sur les requetes GET du navigateur (THE_REQUEST)
#     - on exclut send-contact / routerCities / router pour ne pas
#       casser le formulaire ni creer de boucle
# ============================================================
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
RewriteCond %{THE_REQUEST} \s/+((?!send-contact|routerCities|router)[^?\s]+)\.php[\s?] [NC]
RewriteRule ^ https://www.nuances-facade.fr/%1 [R=301,L]

# ============================================================
#  4. Supprimer le slash final (sauf racine)  ->  301
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/+$ https://www.nuances-facade.fr/$1 [R=301,L]

# ============================================================
#  5. Pages villes : /prestation/xxx  ->  routerCities.php (interne)
# ============================================================
RewriteRule ^prestation/([A-Za-z0-9-]+)/?$ routerCities.php?route=$1 [L,QSA]

# ============================================================
#  6. URL propre  ->  fichier .php correspondant (interne, pas de 301)
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+?)/?$ /$1.php [L]

# ============================================================
#  Cache navigateur des images (inchange)
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
